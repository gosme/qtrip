{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "city",
      "description"
    ],
    "properties": {
      "id": {
        "type": [
          "string",
          "number"
        ]
      },
      "city": {
        "type": "string"
      },
      "description": {
        "type": "string"
      },
      "image": {
        "type": "string"
      }
    },
    "additionalProperties": true
  }
}
